# Web app runtime configuration
# Copy this file to `.env.local` before starting `apps/web`.

# Required: Stellar network selection for the web client.
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Required: Soroban RPC endpoint used for contract reads and writes.
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Required: Horizon endpoint used for account and balance lookups.
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Required: Network passphrase matching the selected Stellar network.
NEXT_PUBLIC_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Required: Payment Stream Soroban contract ID from your deployment.
NEXT_PUBLIC_PAYMENT_STREAM_CONTRACT_ID=

# Required: Distributor Soroban contract ID from your deployment.
NEXT_PUBLIC_DISTRIBUTOR_CONTRACT_ID=

# Optional: Public app metadata.
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Fundable Stellar
NEXT_PUBLIC_APP_DESCRIPTION=Create payment streams and token distributions on Stellar.

# Optional: Backend and integration endpoints.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_BACKEND_BASE_URL=
NEXT_PUBLIC_POLYGON_RPC_URL=https://polygon-rpc.com

# Optional: Local development feature flags.
NEXT_PUBLIC_OFFRAMP_MOCK=false

# Deployment script configuration
NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Account used for deployment
STELLAR_SECRET_KEY=your_secret_key_here

# Network Passphrase
TESTNET_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Optional: Custom network passphrases
MAINNET_NETWORK_PASSPHRASE="Public Global Stellar Network ; September 2015"
